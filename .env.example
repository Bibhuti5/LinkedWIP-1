# DevSocial Platform Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DB_USERNAME=devsocial
DB_PASSWORD=devsocial123
DATABASE_URL=jdbc:postgresql://localhost:5432/devsocial

# JWT Configuration
JWT_SECRET=your-very-long-and-secure-secret-key-that-should-be-at-least-256-bits-long

# OAuth2 Configuration - GitHub
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# OAuth2 Configuration - Google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# AWS Configuration (for media service)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=us-east-1

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Monitoring Configuration
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@devsocial.com

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/devsocial/

# Development/Production Environment
ENVIRONMENT=development
DEBUG_MODE=true