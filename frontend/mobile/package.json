{
  "name": "devsocial-mobile",
  "version": "1.0.0",
  "description": "DevSocial - Developer Social Platform Mobile Application",
  "main": "index.js",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace DevSocial.xcworkspace -scheme DevSocial -configuration Release -destination generic/platform=iOS -archivePath DevSocial.xcarchive archive",
    "clean": "react-native clean-project-auto",
    "postinstall": "cd ios && pod install"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.19.3",
    "@react-native-camera-roll/camera-roll": "^5.7.4",
    "@react-native-community/netinfo": "^9.4.1",
    "@react-native-picker/picker": "^2.4.10",
    "@react-navigation/native": "^6.1.8",
    "@react-navigation/stack": "^6.3.18",
    "@react-navigation/bottom-tabs": "^6.5.9",
    "@react-navigation/drawer": "^6.6.4",
    "@reduxjs/toolkit": "^1.9.7",
    "react": "18.2.0",
    "react-native": "0.72.6",
    "react-native-safe-area-context": "^4.7.4",
    "react-native-screens": "^3.25.0",
    "react-native-gesture-handler": "^2.13.1",
    "react-native-reanimated": "^3.5.4",
    "react-native-vector-icons": "^10.0.0",
    "react-native-svg": "^13.14.0",
    "react-native-image-picker": "^5.6.0",
    "react-native-document-picker": "^9.1.1",
    "react-native-permissions": "^3.9.3",
    "react-native-keychain": "^8.1.3",
    "react-native-push-notification": "^8.1.1",
    "react-native-socket.io-client": "^4.7.2",
    "react-redux": "^8.1.3",
    "redux-persist": "^6.0.0",
    "axios": "^1.5.1",
    "react-query": "^3.39.3",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.1",
    "react-hook-form": "^7.47.0",
    "react-native-paper": "^5.10.6",
    "react-native-video": "^5.2.1",
    "react-native-fast-image": "^8.6.3",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-modal": "^13.0.1",
    "react-native-toast-message": "^2.1.6",
    "react-native-super-grid": "^4.9.7",
    "react-native-swipe-list-view": "^3.2.9",
    "react-native-webview": "^13.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@tsconfig/react-native": "^3.0.0",
    "@types/react": "^18.0.24",
    "@types/react-test-renderer": "^18.0.0",
    "@types/lodash": "^4.14.199",
    "@types/uuid": "^9.0.5",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "babel-jest": "^29.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.2.1",
    "metro-react-native-babel-preset": "0.76.8",
    "prettier": "^2.4.1",
    "react-test-renderer": "18.2.0",
    "typescript": "4.8.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "react-native",
    "typescript",
    "social-platform",
    "developer-community",
    "mobile-app",
    "real-time-messaging"
  ],
  "author": "DevSocial Team",
  "license": "MIT",
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
}