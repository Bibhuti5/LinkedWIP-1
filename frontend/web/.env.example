# DevSocial Web Application Environment Configuration

# API Configuration
VITE_API_BASE_URL=http://localhost:8080

# Authentication
VITE_JWT_SECRET=devSocialSecretKeyThatIsVeryLongAndSecureForProductionUseWithAtLeast256Bits

# OAuth Configuration
VITE_GITHUB_CLIENT_ID=your_github_client_id
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# WebSocket Configuration
VITE_WS_URL=ws://localhost:8080/ws

# Application Configuration
VITE_APP_NAME=DevSocial
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Developer Social Platform

# Feature Flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_PWA=true
VITE_ENABLE_NOTIFICATIONS=true

# Development Configuration
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug